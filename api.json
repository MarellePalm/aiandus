{
    "openapi": "3.1.0",
    "info": {
        "title": "Aiandus API",
        "version": "0.0.1",
        "description": "OpenAPI documentation for Aiandus backend endpoints."
    },
    "servers": [
        {
            "url": "http://localhost/api"
        }
    ],
    "tags": [
        {
            "name": "System",
            "description": "System health and availability endpoints"
        },
        {
            "name": "Weather",
            "description": "Ilmaandmed (OpenWeather + valikuline WeatherAPI). N\u00f5uab sisselogimist (sessioon)."
        }
    ],
    "paths": {
        "/health": {
            "get": {
                "operationId": "apiHealth",
                "description": "Returns backend status information for monitoring and smoke checks.",
                "summary": "Health check",
                "tags": [
                    "System"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "const": "ok"
                                        },
                                        "app": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "status",
                                        "app"
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/weather": {
            "get": {
                "operationId": "apiWeather",
                "description": "Tagastab vahem\u00e4lust (1 h) kogutud ilma: temperatuur, niiskus, tuul, asukoht, p\u00e4evane max/min, iga p\u00e4eva kokkuv\u00f5te, p\u00e4ike/kuu. Kasutab OpenWeatherMap API-t; WeatherAPI v\u00f5ti annab t\u00e4psema kuu faasi ja ikooni URL-i.",
                "summary": "Praegune ilm ja l\u00fchike prognoos",
                "tags": [
                    "Weather"
                ],
                "parameters": [
                    {
                        "name": "lat",
                        "in": "query",
                        "required": true,
                        "description": "Laiuskraad (WGS84), numbriline.",
                        "schema": {
                            "type": "number"
                        }
                    },
                    {
                        "name": "lon",
                        "in": "query",
                        "required": true,
                        "description": "Pikkuskraad (WGS84), numbriline.",
                        "schema": {
                            "type": "number"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Ilmaandmed edukalt koostatud.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "useOpenWeather": {
                                            "type": "boolean"
                                        },
                                        "temp": {
                                            "type": [
                                                "number",
                                                "null"
                                            ]
                                        },
                                        "humidity": {
                                            "type": [
                                                "integer",
                                                "null"
                                            ]
                                        },
                                        "windSpeed": {
                                            "type": [
                                                "number",
                                                "null"
                                            ]
                                        },
                                        "locationName": {
                                            "type": [
                                                "string",
                                                "null"
                                            ]
                                        },
                                        "tMax": {
                                            "type": [
                                                "number",
                                                "null"
                                            ]
                                        },
                                        "tMin": {
                                            "type": [
                                                "number",
                                                "null"
                                            ]
                                        },
                                        "daily": {
                                            "type": "array",
                                            "items": {
                                                "type": "object",
                                                "additionalProperties": {}
                                            }
                                        },
                                        "updatedAt": {
                                            "type": "string"
                                        },
                                        "openWeatherIcon": {
                                            "type": "string"
                                        },
                                        "openWeatherLabel": {
                                            "type": "string"
                                        },
                                        "sunrise": {
                                            "type": [
                                                "string",
                                                "null"
                                            ]
                                        },
                                        "sunset": {
                                            "type": [
                                                "string",
                                                "null"
                                            ]
                                        },
                                        "astronomy": {
                                            "type": [
                                                "object",
                                                "null"
                                            ],
                                            "additionalProperties": {}
                                        },
                                        "weatherapiIcon": {
                                            "type": [
                                                "string",
                                                "null"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "useOpenWeather",
                                        "temp",
                                        "humidity",
                                        "windSpeed",
                                        "locationName",
                                        "tMax",
                                        "tMin",
                                        "daily",
                                        "updatedAt",
                                        "openWeatherIcon",
                                        "openWeatherLabel",
                                        "sunrise",
                                        "sunset",
                                        "astronomy",
                                        "weatherapiIcon"
                                    ]
                                }
                            }
                        }
                    },
                    "502": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "anyOf": [
                                        {
                                            "type": "object",
                                            "properties": {
                                                "message": {
                                                    "type": "string"
                                                }
                                            },
                                            "required": [
                                                "message"
                                            ]
                                        },
                                        {
                                            "type": "object",
                                            "properties": {
                                                "message": {
                                                    "type": "string",
                                                    "const": "Ilmaandmete p\u00e4ring eba\u00f5nnestus"
                                                }
                                            },
                                            "required": [
                                                "message"
                                            ]
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "const": "Asukoht (lat/lon) puudub. Luba brauseris asukoha jagamine."
                                        }
                                    },
                                    "required": [
                                        "message"
                                    ]
                                }
                            }
                        }
                    },
                    "503": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "const": "OPENWEATHER_API_KEY pole .env failis. Lisa v\u00f5ti ja k\u00e4ivita: php artisan config:clear"
                                        }
                                    },
                                    "required": [
                                        "message"
                                    ]
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/AuthenticationException"
                    }
                }
            }
        }
    },
    "components": {
        "responses": {
            "AuthenticationException": {
                "description": "Unauthenticated",
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "description": "Error overview."
                                }
                            },
                            "required": [
                                "message"
                            ]
                        }
                    }
                }
            }
        }
    }
}