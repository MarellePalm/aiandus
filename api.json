    "paths": {
        "/health": {
            "get": {
                "operationId": "apiHealth",
                "description": "Returns backend status information for monitoring and smoke checks.",
                "summary": "Health check",
                "tags": [
                    "System"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "const": "ok"
                                        },
                                        "app": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "status",
                                        "app"
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/weather": {
