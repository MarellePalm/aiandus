{
    "openapi": "3.1.0",
    "info": {
        "title": "Laravel",
        "version": "0.0.1",
        "description": "OpenAPI documentation for Aiandus backend endpoints."
    },
    "servers": [
        {
            "url": "http://localhost/api"
        }
    ],
    "tags": [
        {
            "name": "System",
            "description": "System health and availability endpoints"
        }
